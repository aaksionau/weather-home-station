[
  {
    "WorkflowName": "WeatherAlertRules",
    "Rules": [
      {
        "RuleName": "HighTemperatureAlert",
        "RuleExpressionType": "LambdaExpression",
        "Expression": "reading.Temperature >= 90",
        "ErrorMessage": "Temperature is at or above 90F.",
        "SuccessEvent": "HighTemperature",
        "Properties": {
          "Severity": "Warning"
        }
      },
      {
        "RuleName": "FreezingTemperatureAlert",
        "RuleExpressionType": "LambdaExpression",
        "Expression": "reading.Temperature <= 32",
        "ErrorMessage": "Temperature is at or below 32F (freezing).",
        "SuccessEvent": "FreezingTemperature",
        "Properties": {
          "Severity": "Warning"
        }
      },
      {
        "RuleName": "HeatIndexDangerAlert",
        "RuleExpressionType": "LambdaExpression",
        "Expression": "reading.HeatIndex >= 103",
        "ErrorMessage": "Heat index is at or above 103F (NWS danger threshold).",
        "SuccessEvent": "HeatIndexDanger",
        "Properties": {
          "Severity": "Critical"
        }
      },
      {
        "RuleName": "HighHumidityAlert",
        "RuleExpressionType": "LambdaExpression",
        "Expression": "reading.Humidity >= 90",
        "ErrorMessage": "Relative humidity is at or above 90%.",
        "SuccessEvent": "HighHumidity",
        "Properties": {
          "Severity": "Info"
        }
      },
      {
        "RuleName": "LowPressureAlert",
        "RuleExpressionType": "LambdaExpression",
        "Expression": "reading.Pressure <= 1000",
        "ErrorMessage": "Barometric pressure has dropped to or below 1000 hPa, indicating possible stormy weather.",
        "SuccessEvent": "LowPressure",
        "Properties": {
          "Severity": "Warning"
        }
      }
    ]
  }
]
